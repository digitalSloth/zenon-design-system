{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/blockchain/**",
              "components/core/**",
              "ui_kits/explorer/**",
              "ui_kits/wallet/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:JetBrains Mono|Space Grotesk))/i]",
        "message": "Font not provided by the design system. Available: JetBrains Mono, Space Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Address'] > JSXAttribute > JSXIdentifier[name!=/^(?:address|start|end|truncate|copy|href|className|key|ref|className|style|children)$/]",
        "message": "<Address> doesn't accept that prop. Declared props: address, start, end, truncate, copy, href, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Amount'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|decimals|symbol|fiat|compact|locale|dimTrailingZeros|className|key|ref|className|style|children)$/]",
        "message": "<Amount> doesn't accept that prop. Declared props: value, decimals, symbol, fiat, compact, locale, dimTrailingZeros, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|className|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|secondary|destructive|outline|success|warning|pending|highlight)$/]",
        "message": "<Badge> variant must be one of 'default' | 'secondary' | 'destructive' | 'outline' | 'success' | 'warning' | 'pending' | 'highlight'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|href|className|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, href, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|destructive|outline|secondary|ghost|link)$/]",
        "message": "<Button> variant must be one of 'default' | 'destructive' | 'outline' | 'secondary' | 'ghost' | 'link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:default|xs|sm|lg|icon|icon-sm|icon-lg)$/]",
        "message": "<Button> size must be one of 'default' | 'xs' | 'sm' | 'lg' | 'icon' | 'icon-sm' | 'icon-lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:numeric|className|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: numeric, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='NetworkGlyph'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|title|className|key|ref|className|style|children)$/]",
        "message": "<NetworkGlyph> doesn't accept that prop. Declared props: name, size, title, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onCheckedChange|className|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onCheckedChange, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TokenIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:symbol|src|size|className|key|ref|className|style|children)$/]",
        "message": "<TokenIcon> doesn't accept that prop. Declared props: symbol, src, size, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TxDirection'] > JSXAttribute > JSXIdentifier[name!=/^(?:direction|label|className|key|ref|className|style|children)$/]",
        "message": "<TxDirection> doesn't accept that prop. Declared props: direction, label, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TxDirection'] > JSXAttribute[name.name='direction'] > Literal[value!=/^(?:in|out)$/]",
        "message": "<TxDirection> direction must be one of 'in' | 'out'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TxStatus'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|label|className|key|ref|className|style|children)$/]",
        "message": "<TxStatus> doesn't accept that prop. Declared props: status, label, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TxStatus'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:pending|confirming|success|failed)$/]",
        "message": "<TxStatus> status must be one of 'pending' | 'confirming' | 'success' | 'failed'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
